// ─── Feedback System ──────────────────────────────────────────────────────────

model UserFeedback {
  id         String            @id @default(uuid())
  userId     String
  companyId  String?
  category   String            @default("GENERAL")
  priority   String            @default("MEDIUM")
  status     String            @default("OPEN")
  title      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  resolvedAt DateTime?
  user       User              @relation("UserFeedbacks", fields: [userId], references: [id])
  messages   FeedbackMessage[]

  @@index([userId])
  @@index([status])
  @@index([companyId])
}

model FeedbackMessage {
  id           String               @id @default(uuid())
  feedbackId   String
  senderId     String?
  content      String
  isAdminReply Boolean              @default(false)
  createdAt    DateTime             @default(now())
  feedback     UserFeedback         @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  sender       User?                @relation("FeedbackMessageSender", fields: [senderId], references: [id])
  attachments  FeedbackAttachment[]

  @@index([feedbackId])
  @@index([senderId])
}

model FeedbackAttachment {
  id        String          @id @default(uuid())
  messageId String
  url       String
  filename  String
  size      Int
  mimeType  String
  createdAt DateTime        @default(now())
  message   FeedbackMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

// ─── Unified File Storage ──────────────────────────────────────────────────

model FileRecord {
  id           String    @id @default(uuid())
  filename     String // original user filename
  storedName   String // uuid-based filename on disk
  url          String // served URL (/uploads/... or /api/files/...)
  path         String // absolute disk path
  mimeType     String
  size         Int // bytes
  category     String    @default("general") // profile_pictures|documents|feedback|general|other
  context      String? // e.g. "feedback:threadId", "project:id"
  checksum     String? // MD5 hex for integrity verification
  syncedAt     DateTime? // last time confirmed on storage
  uploadedById String?
  uploadedBy   User?     @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  thinkTankAttachments ThinkTankIdeaAttachment[]

  @@index([uploadedById])
  @@index([category])
  @@index([context])
  @@index([createdAt])
}

model ThinkTankIdeaCycle {
  id          String               @id @default(uuid())
  companyId   String
  windowStart DateTime
  windowEnd   DateTime
  revealAt    DateTime
  cycleLabel  String?
  renewalAt   DateTime?
  status      ThinkTankCycleStatus @default(ACTIVE)
  revealedAt  DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ideas       ThinkTankIdea[]
  votes       ThinkTankIdeaVote[]
  pointAccounts ThinkTankPointAccount[]

  @@index([companyId, revealAt])
  @@index([status])
}

model ThinkTankIdea {
  id                 String                    @id @default(uuid())
  companyId          String
  cycleId            String
  topic              String
  description        String                    @db.Text
  category           ThinkTankIdeaCategory
  status             ThinkTankIdeaStatus       @default(DRAFT)
  reviewStage        String                    @default("SUBMITTED")
  plannerEncrypted   String                    @db.Text
  plannerHash        String
  visibleAuthorId    String?
  revealedAt         DateTime?
  duplicateDecision  ThinkTankDuplicateDecision?
  weightedScore      Float                     @default(0)
  voteCount          Int                       @default(0)
  implementationStatus String                  @default("NOT_STARTED")
  decisionNotes      String?                   @db.Text
  shortlistedAt      DateTime?
  approvedAt         DateTime?
  implementedAt      DateTime?
  decisionById       String?
  finalScore         Float                     @default(0)
  communityScore     Float                     @default(0)
  reviewerScore      Float                     @default(0)
  ideaReadinessScore Float                     @default(0)
  questionCount      Int                       @default(0)
  isVetoed           Boolean                   @default(false)
  vetoedAt           DateTime?
  vetoedById         String?
  vetoReason         String?                   @db.Text
  metadata           Json?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  company            Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cycle              ThinkTankIdeaCycle        @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  visibleAuthor      User?                     @relation("ThinkTankVisibleAuthor", fields: [visibleAuthorId], references: [id], onDelete: SetNull)
  decisionBy         User?                     @relation("ThinkTankDecisionBy", fields: [decisionById], references: [id], onDelete: SetNull)
  vetoedBy          User?                      @relation("ThinkTankVetoBy", fields: [vetoedById], references: [id], onDelete: SetNull)
  partners           ThinkTankIdeaPartner[]
  teamMembers        ThinkTankIdeaTeamMember[]
  votes              ThinkTankIdeaVote[]
  attachments        ThinkTankIdeaAttachment[]
  auditEvents        ThinkTankIdeaAuditEvent[]
  comments           ThinkTankIdeaComment[]
  questions          ThinkTankIdeaQuestion[]
  reviewerScores     ThinkTankIdeaReviewerScore[]
  duplicateMatches   ThinkTankIdeaDuplicateMatch[] @relation("ThinkTankDuplicateMatches")
  duplicateSources   ThinkTankIdeaDuplicateMatch[] @relation("ThinkTankDuplicateSources")
  pointsMappings     ThinkTankPointsMapping[]

  @@index([companyId, status])
  @@index([cycleId])
  @@index([category])
  @@index([plannerHash])
  @@index([revealedAt])
  @@index([reviewStage])
  @@index([implementationStatus])
  @@index([isVetoed])
}

model ThinkTankIdeaPartner {
  id              String                 @id @default(uuid())
  ideaId          String
  userEncrypted   String                 @db.Text
  userHash        String
  visibleUserId   String?
  roleType        ThinkTankParticipantRole
  createdAt       DateTime               @default(now())
  idea            ThinkTankIdea          @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  visibleUser     User?                  @relation("ThinkTankVisiblePartner", fields: [visibleUserId], references: [id], onDelete: SetNull)

  @@unique([ideaId, userHash])
  @@index([ideaId, roleType])
}

model ThinkTankIdeaTeamMember {
  id              String                 @id @default(uuid())
  ideaId          String
  userEncrypted   String                 @db.Text
  userHash        String
  visibleUserId   String?
  roleType        ThinkTankParticipantRole @default(CO_OPTED)
  sourceCategory  ThinkTankIdeaCategory?
  createdAt       DateTime               @default(now())
  idea            ThinkTankIdea          @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  visibleUser     User?                  @relation("ThinkTankVisibleTeamMember", fields: [visibleUserId], references: [id], onDelete: SetNull)

  @@unique([ideaId, userHash])
  @@index([ideaId])
}

model ThinkTankIdeaVote {
  id             String            @id @default(uuid())
  ideaId         String
  cycleId        String
  companyId      String
  voterEncrypted String            @db.Text
  voterHash      String
  vote           ThinkTankVoteState
  weight         Int
  weightedValue  Int
  pointAllocation Int              @default(0)
  maxAllowedPoints Int             @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  idea           ThinkTankIdea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  cycle          ThinkTankIdeaCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([ideaId, cycleId, voterHash])
  @@index([ideaId])
  @@index([cycleId])
}

model ThinkTankPointAccount {
  id              String    @id @default(uuid())
  companyId       String
  cycleId         String
  userId          String
  basePoints      Int
  maxPerIdeaPoints Int
  allocatedPoints Int       @default(0)
  remainingPoints Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cycle           ThinkTankIdeaCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cycleId, userId])
  @@index([companyId, cycleId])
}

model ThinkTankIdeaAttachment {
  id           String        @id @default(uuid())
  ideaId       String
  fileRecordId String?
  url          String
  filename     String
  mimeType     String
  size         Int
  scrubStatus  String?       @default("SCRUBBED")
  createdAt    DateTime      @default(now())
  idea         ThinkTankIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  fileRecord   FileRecord?   @relation(fields: [fileRecordId], references: [id], onDelete: SetNull)

  @@index([ideaId])
  @@index([fileRecordId])
}

model ThinkTankIdeaAuditEvent {
  id          String     @id @default(uuid())
  ideaId       String?
  actorUserId  String?
  action       String
  outcome      String
  entityId     String?
  metadata     Json?
  createdAt    DateTime  @default(now())
  idea         ThinkTankIdea? @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  actor        User?     @relation("ThinkTankAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ideaId, createdAt])
  @@index([actorUserId])
}

model ThinkTankIdeaDuplicateMatch {
  id               String                    @id @default(uuid())
  ideaId           String
  matchedIdeaId    String
  similarityScore  Float
  decision         ThinkTankDuplicateDecision?
  createdAt        DateTime                  @default(now())
  idea             ThinkTankIdea             @relation("ThinkTankDuplicateMatches", fields: [ideaId], references: [id], onDelete: Cascade)
  matchedIdea      ThinkTankIdea             @relation("ThinkTankDuplicateSources", fields: [matchedIdeaId], references: [id], onDelete: Cascade)

  @@index([ideaId])
  @@index([matchedIdeaId])
}

model ThinkTankIdeaComment {
  id          String         @id @default(uuid())
  ideaId       String
  authorUserId String
  content      String         @db.Text
  isInternal   Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  idea         ThinkTankIdea  @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  author       User           @relation("ThinkTankCommentAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([ideaId, createdAt])
  @@index([authorUserId])
}

model ThinkTankIdeaQuestion {
  id             String   @id @default(uuid())
  ideaId         String
  askedByUserId  String
  answeredByUserId String?
  question       String   @db.Text
  answer         String?  @db.Text
  status         String   @default("OPEN")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  answeredAt     DateTime?
  idea           ThinkTankIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  askedBy        User     @relation("ThinkTankQuestionAskedBy", fields: [askedByUserId], references: [id], onDelete: Cascade)
  answeredBy     User?    @relation("ThinkTankQuestionAnsweredBy", fields: [answeredByUserId], references: [id], onDelete: SetNull)

  @@index([ideaId, createdAt])
  @@index([askedByUserId])
  @@index([status])
}

model ThinkTankIdeaReviewerScore {
  id                String   @id @default(uuid())
  ideaId            String
  reviewerUserId    String
  impactScore       Int      @default(0)
  feasibilityScore  Int      @default(0)
  costScore         Int      @default(0)
  speedScore        Int      @default(0)
  strategicFitScore Int      @default(0)
  scalabilityScore  Int      @default(0)
  totalScore        Float    @default(0)
  note              String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  idea              ThinkTankIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  reviewer          User     @relation("ThinkTankReviewerScoreUser", fields: [reviewerUserId], references: [id], onDelete: Cascade)

  @@unique([ideaId, reviewerUserId])
  @@index([reviewerUserId])
}

model ThinkTankPointsMapping {
  id             String   @id @default(uuid())
  ideaId          String
  userEncrypted   String   @db.Text
  userHash        String
  visibleUserId   String?
  points          Float
  awardedAt       DateTime @default(now())
  idea            ThinkTankIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  visibleUser     User?    @relation("ThinkTankVisiblePointUser", fields: [visibleUserId], references: [id], onDelete: SetNull)

  @@index([ideaId])
  @@index([visibleUserId])
}

// ─── Zero-Knowledge Web Vault ───────────────────────────────────────────────

model VaultKeyring {
  id               String   @id @default(uuid())
  userId           String   @unique
  encryptedPrivKey String   @db.Text // Encrypted RSA private key
  publicKey        String   @db.Text // Public RSA key for sharing
  salt             String // Salt used for deriving the wrapping key
  iv               String // IV used for encrypting the private key
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation("UserVaultKeyring", fields: [userId], references: [id], onDelete: Cascade)
}

model VaultFolder {
  id        String      @id @default(uuid())
  userId    String
  name      String
  color     String?     @default("#3b82f6")
  icon      String?     @default("folder")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation("UserVaultFolders", fields: [userId], references: [id], onDelete: Cascade)
  items     VaultItem[]

  @@unique([userId, name])
  @@index([userId])
}

model VaultItem {
  id                 String    @id @default(uuid())
  ownerId            String
  folderId           String?
  type               String    @default("LOGIN") // LOGIN, NOTE, CARD, IDENTITY
  title              String // Plaintext title for searching/display
  username           String? // Plaintext username for searching (often email)
  website            String? // Plaintext URL or app name
  icon               String? // Plaintext icon/favicon URL
  encryptedData      String    @db.Text // AES-GCM encrypted payload (password, notes, custom fields)
  encryptedKey       String    @db.Text // AES key encrypted with owner's public RSA key
  iv                 String // Initialization vector for AES-GCM
  isFavorite         Boolean   @default(false)
  isShared           Boolean   @default(false)
  lastPasswordUpdate DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  owner        User          @relation("OwnerVaultItems", fields: [ownerId], references: [id], onDelete: Cascade)
  folder       VaultFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  sharedAccess VaultAccess[]

  @@index([ownerId])
  @@index([folderId])
}

model VaultAccess {
  id           String   @id @default(uuid())
  itemId       String
  grantedToId  String
  grantedById  String
  encryptedKey String   @db.Text // AES key encrypted with grantedTo user's public RSA key
  canEdit      Boolean  @default(false)
  createdAt    DateTime @default(now())

  item      VaultItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  grantedTo User      @relation("VaultAccessReceived", fields: [grantedToId], references: [id], onDelete: Cascade)
  grantedBy User      @relation("VaultAccessGranted", fields: [grantedById], references: [id], onDelete: Cascade)

  @@unique([itemId, grantedToId])
  @@index([grantedToId])
}
