  isActive        Boolean                   @default(true)
  imageUrl        String?
  attributes      Json // E.g., { "Size": "M", "Color": "Red", "Custom": "Yes" }
  attributeValues VariantAttributeMapping[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([productId])
  @@index([isActive])
}

model VariantAttributeMapping {
  variantId        String
  attributeValueId String
  variant          ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue   ProductAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([variantId, attributeValueId])
  @@index([variantId])
  @@index([attributeValueId])
}

