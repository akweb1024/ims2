generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id                          String                       @id @default(uuid())
  name                        String
  registrationNumber          String?
  domain                      String?
  address                     String?
  phone                       String?
  email                       String?
  website                     String?
  logoUrl                     String?
  fiscalYearStart             Int?
  currency                    String                       @default("INR")
  timezone                    String                       @default("Asia/Kolkata")
  employeeIdPrefix            String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  latitude                    Float?
  longitude                   Float?
  bankAccountHolder           String?
  bankAccountNumber           String?
  bankIfscCode                String?
  bankName                    String?
  bankSwiftCode               String?
  cinNo                       String?
  gstin                       String?
  iecCode                     String?
  legalEntityName             String?
  panNo                       String?
  paymentMode                 String?
  stateCode                   String?
  tagline                     String?
  brandRelationType           String?                      @default("A Brand of")
  invoiceCompanyLogoUrl       String?                      @map("invoiceCompanyLogoUrl")
  universityId                String?
  invoiceTerms                String?
  regdOfficeAddress           String?
  salesOfficeAddress          String?
  invoicePrefix               String?                      @default("INV-")
  proformaPrefix              String?                      @default("PRO-")
  invoiceNextNumber           Int                          @default(1)
  proformaNextNumber          Int                          @default(1)
  accounts                    Account[]
  appConfigurations           AppConfiguration[]
  attendance                  Attendance[]
  bonusSchemas                BonusSchema[]
  brands                      Brand[]
  campaignAudiences           CampaignAudience[]
  chatRooms                   ChatRoom[]
  communications              CommunicationLog[]
  commissionPayouts           CommissionPayout[]
  reconciliationSessions      BankReconciliationSession[]
  automationJobs              AutomationJob[]
  automationRuns              AutomationRun[]
  integrations                CompanyIntegration[]
  companyPerformance          CompanyPerformance[]
  potential                   CompanyPotential?
  conferences                 Conference[]
  coupons                     Coupon[]
  courses                     Course[]
  customers                   CustomerProfile[]
  deals                       Deal[]
  departments                 Department[]
  departmentBudgets           DepartmentBudget[]
  departmentPerformance       DepartmentPerformance[]
  dispatchOrders              DispatchOrder[]
  documentTemplates           DocumentTemplate[]
  emailTemplates              EmailTemplate[]
  employeeCompanyDesignations EmployeeCompanyDesignation[]
  expenseAllocations          EmployeeExpenseAllocation[]
  employeeGoals               EmployeeGoal[]
  employeeKpis                EmployeeKPI[]
  pointLogs                   EmployeePointLog[]
  taskTemplates               EmployeeTaskTemplate[]
  expenseAllocationRules      ExpenseAllocationRule[]
  financialRecords            FinancialRecord[]
  holidays                    Holiday[]
  itAssets                    ITAsset[]
  itDepartmentRevenue         ITDepartmentRevenue[]        @relation("CompanyITRevenue")
  itPerformanceMetrics        ITPerformanceMetric[]        @relation("CompanyITPerformance")
  itProjects                  ITProject[]                  @relation("CompanyITProjects")
  itServices                  ITServiceDefinition[]        @relation("CompanyITServices")
  itTickets                   ITSupportTicket[]
  itTasks                     ITTask[]                     @relation("CompanyITTasks")
  itTimeEntries               ITTimeEntry[]                @relation("CompanyITTimeEntries")
  incentiveSchemas            IncentiveSchema[]
  institutions                Institution[]
  internships                 Internship[]
  inventoryItems              InventoryItem[]
  invoices                    Invoice[]
  issues                      Issue[]
  jobPostings                 JobPosting[]
  journalEntries              JournalEntry[]
  leaveLedgers                LeaveLedger[]
  leaveRequests               LeaveRequest[]
  marketingCampaigns          MarketingCampaign[]
  performanceSnapshots        MonthlyPerformanceSnapshot[]
  onboardingModules           OnboardingModule[]
  payments                    Payment[]
  performanceInsights         PerformanceInsight[]
  performanceReviews          PerformanceReview[]
  productionOrders            ProductionOrder[]
  projects                    Project[]
  purchaseOrders              PurchaseOrder[]
  redGreenDiaries             RedGreenDiary[]
  revenueTransactions         RevenueTransaction[]
  salaryAdvances              SalaryAdvance[]
  salarySlips                 SalarySlip[]
  screeningTemplates          ScreeningTemplate[]
  shifts                      Shift[]
  shiftRosters                ShiftRoster[]
  statutoryConfig             StatutoryConfig?
  subscriptions               Subscription[]
  supportTickets              SupportTicket[]
  tasks                       Task[]
  taxRates                    TaxRate[]
  teamMembers                 TeamMember[]
  thinkTankCycles             ThinkTankIdeaCycle[]
  thinkTankIdeas              ThinkTankIdea[]
  thinkTankPointAccounts      ThinkTankPointAccount[]
  thinkTankVotes              ThinkTankIdeaVote[]
  primaryUsers                User[]                       @relation("PrimaryCompany")
  vendors                     Vendor[]
  warehouses                  Warehouse[]
  workPlans                   WorkPlan[]
  workReports                 WorkReport[]
  workshops                   Workshop[]
  designations                Designation[]                @relation("CompanyToDesignation")
  users                       User[]                       @relation("UserCompanies")
}

model CompanyIntegration {
  id        String   @id @default(uuid())
  companyId String
  provider  String
  key       String
  value     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider])
  @@index([companyId])
}

model AutomationJob {
  id              String          @id @default(uuid())
  companyId       String?
  key             String
  action          String
  title           String
  description     String
  category        String?
  icon            String?
  color           String?
  scheduleLabel   String?
  isActive        Boolean         @default(true)
  requiresCronKey Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  company         Company?        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  runs            AutomationRun[]

  @@unique([companyId, key])
  @@index([companyId])
  @@index([action])
}

model AutomationRun {
  id            String         @id @default(uuid())
  jobId          String
  companyId      String?
  triggeredBy    String?
  status         String
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  durationMs     Int?
  message        String?
  stats          Json?
  error          String?
  createdAt      DateTime      @default(now())
  job            AutomationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  company        Company?      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  triggeredUser  User?         @relation("AutomationRunTrigger", fields: [triggeredBy], references: [id])

  @@index([jobId])
  @@index([companyId])
  @@index([triggeredBy])
  @@index([startedAt])
}

model Department {
  id                     String                       @id @default(uuid())
  companyId              String
  name                   String
  code                   String?
  description            String?
  parentDepartmentId     String?
  headUserId             String?
  isActive               Boolean                      @default(true)
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  company                Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  headUser               User?                        @relation("DepartmentHead", fields: [headUserId], references: [id])
  parentDepartment       Department?                  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  subDepartments         Department[]                 @relation("DepartmentHierarchy")
  budgets                DepartmentBudget[]
  departmentPerformance  DepartmentPerformance[]
  expenseAllocations     EmployeeExpenseAllocation[]
  taskTemplates          EmployeeTaskTemplate[]
  expenseAllocationRules ExpenseAllocationRule[]
  itProjects             ITProject[]                  @relation("DepartmentITProjects")
  jobApplications        JobApplication[]
  jobPostings            JobPosting[]
  performanceSnapshots   MonthlyPerformanceSnapshot[]
  onboardingModules      OnboardingModule[]
  revenueTransactions    RevenueTransaction[]
  users                  User[]                       @relation("DepartmentMembers")
  designations           Designation[]                @relation("DepartmentToDesignation")

  @@unique([companyId, code])
  @@index([companyId])
}

model User {
  id                             String                      @id @default(uuid())
  email                          String                      @unique
  password                       String
  role                           UserRole                    @default(EXECUTIVE)
  isActive                       Boolean                     @default(true)
  emailVerified                  Boolean                     @default(false)
  lastLogin                      DateTime?
  theme                          String                      @default("light")
  notificationsEnabled           Boolean                     @default(true)
  companyId                      String?
  departmentId                   String?
  managerId                      String?
  createdAt                      DateTime                    @default(now())
  updatedAt                      DateTime                    @updatedAt
  name                           String?
  allowedModules                 String[]                    @default(["CORE"])
  roles                          UserRole[]                  @default([EXECUTIVE])
  announcements                  Announcement[]
  auditLogs                      AuditLog[]
  certificates                   Certificate[]
  sentMessages                   ChatMessage[]
  createdDispatchOrders          DispatchOrder[]             @relation("DispatchOrderCreatedBy")
  updatedDispatchOrders          DispatchOrder[]             @relation("DispatchOrderUpdatedBy")
  chatParticipants               ChatParticipant[]
  coAuthorInvitations            CoAuthorInvitation[]
  communications                 CommunicationLog[]          @relation("UserCommunications")
  knowledgeArticleRevisions      KnowledgeArticleRevision[]  @relation("KnowledgeArticleRevisionEditor")
  committeeRoles                 ConferenceCommitteeMember[]
  conferenceRegistrations        ConferenceRegistration[]
  uploadedReconciliationSessions BankReconciliationSession[] @relation("ReconciliationSessionUploader")
  automationRunsTriggered        AutomationRun[]             @relation("AutomationRunTrigger")
  mentoredCourses                Course[]                    @relation("CourseMentor")
  courseDiscussions              CourseDiscussion[]
  courseEnrollments              CourseEnrollment[]
  courseNotes                    CourseNote[]
  customerAssignments            CustomerAssignment[]        @relation("EmployeeAssignments")
  assignedCustomers              CustomerProfile[]           @relation("AssignedCustomers")
  commissionPayoutRequests       CommissionPayout[]          @relation("CommissionPayoutRequester")
  commissionPayoutReviews        CommissionPayout[]          @relation("CommissionPayoutReviewer")
  customerProfile                CustomerProfile?
  deals                          Deal[]
  headOfDepartments              Department[]                @relation("DepartmentHead")
  discussionReplies              DiscussionReply[]
  editorialMemberships           EditorialBoardMember[]
  authoredComments               EmployeeComment[]
  reviewedGoals                  EmployeeGoal[]              @relation("GoalReviewer")
  employeeProfile                EmployeeProfile?
  createdFinanceRecords          FinancialRecord[]           @relation("FinanceCreator")
  goalEvaluations                GoalEvaluation[]
  assignedAssets                 ITAsset[]
  itPerformanceMetrics           ITPerformanceMetric[]       @relation("ITPerformance")
  managedProjects                ITProject[]                 @relation("ProjectManager")
  ledProjects                    ITProject[]                 @relation("TeamLead")
  itProjectComments              ITProjectComment[]          @relation("ITProjectComments")
  itProjectSuggestions           ITProjectSuggestion[]
  itResolutions                  ITSupportTicket[]           @relation("ITResolver")
  itRequests                     ITSupportTicket[]           @relation("ITRequestor")
  assignedITTasks                ITTask[]                    @relation("ITTaskAssignee")
  createdITTasks                 ITTask[]                    @relation("ITTaskCreator")
  reportedITTasks                ITTask[]                    @relation("ITTaskReporter")
  itTaskComments                 ITTaskComment[]             @relation("ITTaskComments")
  itTaskStatusChanges            ITTaskStatusHistory[]       @relation("ITStatusChanger")
  itTimeEntries                  ITTimeEntry[]               @relation("ITTimeEntries")
  assignedInstitutions           Institution[]               @relation("InstitutionOwner")
  mentoredInternships            Internship[]                @relation("InternshipMentor")
  internshipApplications         InternshipApplication[]
  screeningsSubmitted            InterviewScreening[]        @relation("ScreeningSubmitter")
  assignedIssues                 Issue[]                     @relation("IssueAssignee")
  reportedIssues                 Issue[]                     @relation("IssueReporter")
  issueFollowUps                 IssueFollowUp[]
  managedJournals                Journal[]                   @relation("JournalEditor")
  managedJournalsAsManager       Journal[]                   @relation("JournalManager")
  postedJournalEntries           JournalEntry[]
  reviewerProfiles               JournalReviewer[]           @relation("ReviewerProfile")
  knowledgeArticles              KnowledgeArticle[]
  sentLMSEmails                  LMSEmailLog[]
  mentorPayments                 LMSMentorPayment[]          @relation("MentorPayments")
  approvedLeaves                 LeaveRequest[]              @relation("LeaveApprover")
  sentCommunications             ManuscriptCommunication[]   @relation("SentCommunications")
  receivedCommunications         ManuscriptCommunication[]   @relation("ReceivedCommunications")
  manuscriptDrafts               ManuscriptDraft[]
  manuscriptRevisions            ManuscriptRevision[]
  manuscriptStatusChanges        ManuscriptStatusHistory[]
  mentorSessions                 MentorSession[]             @relation("SessionMentor")
  notifications                  Notification[]
  paperReviews                   PaperReview[]
  passwordResetTokens            PasswordResetToken[]
  peerReviewsGiven               PeerReview[]                @relation("PeerReviewer")
  evaluationsConducted           PerformanceEvaluation[]     @relation("EvaluatorUser")
  performanceReviews             PerformanceReview[]         @relation("Reviewer")
  plagiarismReports              PlagiarismReport[]          @relation("PlagiarismChecker")
  businessLedProjects            Project[]                   @relation("BusinessTeamLead")
  businessProjects               Project[]                   @relation("BusinessProjectManager")
  projectMemberships             ProjectMember[]
  pushSubscriptions              PushSubscription[]
  qualityReports                 QualityReport[]             @relation("QualityChecker")
  quizAttempts                   QuizAttempt[]
  interviewsConducted            RecruitmentInterview[]      @relation("RecruitmentInterviewer")
  redGreenEntriesRecorded        RedGreenDiary[]             @relation("DiaryRecorder")
  redGreenEntriesTarget          RedGreenDiary[]             @relation("DiaryTarget")
  reviews                        Review[]
  assignedReviews                ReviewAssignment[]          @relation("AssignedReviews")
  issuedCertificates             ReviewCertificate[]         @relation("IssuedCertificates")
  validatedReports               ReviewReport[]              @relation("ValidatedReports")
  incrementReviews               SalaryIncrementReview[]     @relation("IncrementReviewer")
  screeningTemplatesCreated      ScreeningTemplate[]
  assignedByTasks                StageAssignment[]           @relation("TaskAssigner")
  assignedTasks                  StageAssignment[]           @relation("TaskAssignee")
  movedStocks                    StockMovement[]             @relation("StockMover")
  assignedSubscriptions          Subscription[]              @relation("AssignedSalesExecutive")
  assignedTickets                SupportTicket[]             @relation("AssignedTickets")
  createdTasks                   Task[]                      @relation("TaskAssigner")
  tasks                          Task[]
  managedTeamMembers             TeamMember[]                @relation("ManagerTeamMembers")
  teamMemberships                TeamMember[]                @relation("UserTeamMemberships")
  company                        Company?                    @relation("PrimaryCompany", fields: [companyId], references: [id])
  department                     Department?                 @relation("DepartmentMembers", fields: [departmentId], references: [id])
  manager                        User?                       @relation("ManagementChain", fields: [managerId], references: [id])
  subordinates                   User[]                      @relation("ManagementChain")
  lessonProgress                 UserLessonProgress[]
  managedWarehouses              Warehouse[]                 @relation("WarehouseManager")
  workPlanComments               WorkPlanComment[]
  workReportComments             WorkReportComment[]         @relation("WorkReportCommentAuthor")
  mentoredWorkshops              Workshop[]                  @relation("WorkshopMentor")
  workshopEnrollments            WorkshopEnrollment[]
  assignedToCustomers            CustomerProfile[]           @relation("CustomerToExecutives")
  taggedITProjects               ITProject[]                 @relation("ProjectTaggedEmployees")
  companies                      Company[]                   @relation("UserCompanies")
  feedbacks                      UserFeedback[]              @relation("UserFeedbacks")
  feedbackMessages               FeedbackMessage[]           @relation("FeedbackMessageSender")
  files                          FileRecord[]
  thinkTankVisibleIdeas          ThinkTankIdea[]             @relation("ThinkTankVisibleAuthor")
  thinkTankDecisionIdeas         ThinkTankIdea[]             @relation("ThinkTankDecisionBy")
  thinkTankVetoIdeas             ThinkTankIdea[]             @relation("ThinkTankVetoBy")
  thinkTankVisiblePartners       ThinkTankIdeaPartner[]      @relation("ThinkTankVisiblePartner")
  thinkTankVisibleTeamMembers    ThinkTankIdeaTeamMember[]   @relation("ThinkTankVisibleTeamMember")
  thinkTankAuditEvents           ThinkTankIdeaAuditEvent[]   @relation("ThinkTankAuditActor")
  thinkTankPointAccounts         ThinkTankPointAccount[]
  thinkTankPointsMappings        ThinkTankPointsMapping[]    @relation("ThinkTankVisiblePointUser")
  thinkTankComments              ThinkTankIdeaComment[]      @relation("ThinkTankCommentAuthor")
  thinkTankAskedQuestions        ThinkTankIdeaQuestion[]     @relation("ThinkTankQuestionAskedBy")
  thinkTankAnsweredQuestions     ThinkTankIdeaQuestion[]     @relation("ThinkTankQuestionAnsweredBy")
  thinkTankReviewerScores        ThinkTankIdeaReviewerScore[] @relation("ThinkTankReviewerScoreUser")
  vaultKeyring                   VaultKeyring?               @relation("UserVaultKeyring")
  vaultFolders                   VaultFolder[]               @relation("UserVaultFolders")
  ownedVaultItems                VaultItem[]                 @relation("OwnerVaultItems")
  vaultAccessReceived            VaultAccess[]               @relation("VaultAccessReceived")
  vaultAccessGranted             VaultAccess[]               @relation("VaultAccessGranted")

  @@index([email])
  @@index([role])
  @@index([companyId])
  @@index([departmentId])
}

model TeamMember {
  id         String   @id @default(uuid())
  managerId  String
  userId     String
  companyId  String
  role       String?
  assignedAt DateTime @default(now())
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  company    Company  @relation(fields: [companyId], references: [id])
  manager    User     @relation("ManagerTeamMembers", fields: [managerId], references: [id], onDelete: Cascade)
  user       User     @relation("UserTeamMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([managerId, userId, companyId])
  @@index([managerId])
  @@index([userId])
  @@index([companyId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Announcement {
  id         String    @id @default(uuid())
  title      String
  content    String
  authorId   String
  targetRole String    @default("ALL")
  priority   String    @default("NORMAL")
  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  author     User      @relation(fields: [authorId], references: [id])
}

model KnowledgeArticle {
  id           String                 @id @default(uuid())
  title        String
  content      String
  category     String
  targetRole   String                 @default("ALL")
  authorId     String
  views        Int                    @default(0)
  status       KnowledgeArticleStatus @default(PUBLISHED)
  version      Int                    @default(1)
  publishedAt  DateTime?
  reviewedAt   DateTime?
  lastEditedBy String?
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  author       User                   @relation(fields: [authorId], references: [id])
  revisions    KnowledgeArticleRevision[]

  @@index([category])
  @@index([status])
  @@index([targetRole])
}

model KnowledgeArticleRevision {
  id         String           @id @default(uuid())
  articleId  String
  editorId   String?
  version    Int
  title      String
  content    String
  category   String
  targetRole String
  status     KnowledgeArticleStatus
  notes      String?
  createdAt  DateTime         @default(now())
  article    KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  editor     User?            @relation("KnowledgeArticleRevisionEditor", fields: [editorId], references: [id])

  @@index([articleId])
  @@index([editorId])
  @@index([createdAt])
}

model CustomerProfile {
  id                  String               @id @default(uuid())
  userId              String               @unique
  customerType        CustomerType
  assignedToUserId    String?
  name                String
  organizationName    String?
  primaryEmail        String
  secondaryEmail      String?
  primaryPhone        String
  secondaryPhone      String?
  gstVatTaxId         String?
  billingAddress      String?
  shippingAddress     String?
  country             String?
  state               String?
  city                String?
  pincode             String?
  preferredChannel    String?
  notes               String?
  tags                String?
  leadStatus          LeadStatus?          @default(NEW)
  leadScore           Int?                 @default(0)
  source              String?              @default("DIRECT")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  companyId           String?
  designation         CustomerDesignation?
  institutionId       String?
  billingCity         String?
  billingCountry      String?              @default("India")
  billingPincode      String?
  billingState        String?
  billingStateCode    String?
  shippingCity        String?
  shippingCountry     String?              @default("India")
  shippingPincode     String?
  shippingState       String?
  shippingStateCode   String?
  agencyId            String?
  agencyDetails       AgencyDetails?
  communications      CommunicationLog[]
  commissionPayouts   CommissionPayout[]
  dispatchOrders      DispatchOrder[]
  assignments         CustomerAssignment[]
  agencyPartner       CustomerProfile?     @relation("AgencyToSubCustomers", fields: [agencyId], references: [id])
  subCustomers        CustomerProfile[]    @relation("AgencyToSubCustomers")
  assignedTo          User?                @relation("AssignedCustomers", fields: [assignedToUserId], references: [id])
  company             Company?             @relation(fields: [companyId], references: [id])
  institution         Institution?         @relation("InstitutionToCustomers", fields: [institutionId], references: [id])
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  deals               Deal[]
  agencyInstitutions  Institution[]        @relation("AgencyInstitutions")
  institutionDetails  InstitutionDetails?
  invoices            Invoice[]
  proformaInvoices    ProformaInvoice[]
  revenueTransactions RevenueTransaction[]
  subscriptions       Subscription[]
  supportTickets      SupportTicket[]
  assignedExecutives  User[]               @relation("CustomerToExecutives")

  @@index([customerType])
  @@index([primaryEmail])
  @@index([companyId])
  @@index([institutionId])
  @@index([agencyId])
  @@index([designation])
}

model CommissionPayout {
  id                String                 @id @default(uuid())
  companyId         String?
  agencyProfileId   String
  requestedByUserId String
  reviewedByUserId  String?
  amount            Float
  currency          String                 @default("INR")
  status            CommissionPayoutStatus @default(REQUESTED)
  method            String?                @default("Bank Transfer")
  notes             String?
  paymentReference  String?
  requestedAt       DateTime               @default(now())
  reviewedAt        DateTime?
  paidAt            DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  agencyProfile     CustomerProfile        @relation(fields: [agencyProfileId], references: [id], onDelete: Cascade)
  company           Company?               @relation(fields: [companyId], references: [id])
  requestedBy       User                   @relation("CommissionPayoutRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reviewedBy        User?                  @relation("CommissionPayoutReviewer", fields: [reviewedByUserId], references: [id])

  @@index([agencyProfileId])
  @@index([companyId])
  @@index([status])
  @@index([requestedByUserId])
}

model InstitutionDetails {
  id                String          @id @default(uuid())
  customerProfileId String          @unique
  category          String
  department        String?
  libraryContact    String?
  ipRange           String?
  numberOfUsers     Int?
  numberOfSeats     Int?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  customerProfile   CustomerProfile @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
}

model AgencyDetails {
  id                 String             @id @default(uuid())
  customerProfileId  String             @unique
  companyInfo        String?
  territory          String?
  region             String?
  primaryContact     String?
  commissionTerms    String?
  yearsOfExperience  Int?
  workingRegions     String[]           @default([])
  institutionTypes   String[]           @default([])
  agreementSigned    Boolean            @default(false)
  gstNumber          String?
  hasPaymentDisputes Boolean            @default(false)
  creditLimit        Float              @default(0)
  riskFlag           Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  discountRate       Float              @default(0)
  discountTier       String?            @default("GOLD")
  tierMetadata       Json?
  customerProfile    CustomerProfile    @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  performance        AgencyPerformance?
  subscriptions      Subscription[]
}

model AgencyPerformance {
  id                       String        @id @default(uuid())
  agencyDetailsId          String        @unique
  businessLastYear         Float         @default(0)
  targetCurrentYear        Float         @default(0)
  avgOrdersPerMonth        Float         @default(0)
  rating                   Float         @default(0)
  category                 String        @default("MODERATE")
  strategicFitScore        Int           @default(0)
  managementRecommendation String        @default("MAINTAIN")
  profileCompletion        Int           @default(0)
  renewalSuccessRate       Float         @default(0)
  lastAuditDate            DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  agencyDetails            AgencyDetails @relation(fields: [agencyDetailsId], references: [id], onDelete: Cascade)
}

model Institution {
  id                  String               @id @default(uuid())
  name                String
  code                String               @unique
  type                InstitutionType
  category            String?
  establishedYear     Int?
  accreditation       String?
  primaryEmail        String?
  secondaryEmail      String?
  primaryPhone        String?
  secondaryPhone      String?
  website             String?
  address             String?
  city                String?
  state               String?
  country             String               @default("India")
  pincode             String?
  totalStudents       Int?
  totalFaculty        Int?
  totalStaff          Int?
  libraryBudget       Float?
  ipRange             String?
  notes               String?
  logo                String?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  companyId           String?
  assignedToUserId    String?
  domain              String?
  agencyId            String?
  universityId        String?
  communications      CommunicationLog[]
  customers           CustomerProfile[]    @relation("InstitutionToCustomers")
  agency              CustomerProfile?     @relation("AgencyInstitutions", fields: [agencyId], references: [id])
  assignedTo          User?                @relation("InstitutionOwner", fields: [assignedToUserId], references: [id])
  company             Company?             @relation(fields: [companyId], references: [id])
  university          Institution?         @relation("UniversityToAffiliate", fields: [universityId], references: [id])
  affiliates          Institution[]        @relation("UniversityToAffiliate")
  revenueTransactions RevenueTransaction[]
  subscriptions       Subscription[]

  @@index([code])
  @@index([type])
  @@index([companyId])
}

model CustomerAssignment {
