model ManuscriptDraft {
  id          String   @id @default(uuid())
  authorId    String
  journalId   String
  title       String?
  abstract    String?
  keywords    String?
  fileUrl     String?
  metadata    Json?
  step        Int      @default(1)
  isSubmitted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  journal     Journal  @relation(fields: [journalId], references: [id])

  @@index([authorId])
  @@index([journalId])
  @@index([isSubmitted])
}

model PerformanceEvaluation {
  id          String          @id @default(uuid())
  employeeId  String
  evaluatorId String
  period      String
  periodType  String
  scores      Json
  feedback    String?
  rating      Float?
  status      String          @default("DRAFT")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  employee    EmployeeProfile @relation("EvaluatedEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  evaluator   User            @relation("EvaluatorUser", fields: [evaluatorId], references: [id])

  @@unique([employeeId, period])
  @@index([employeeId])
  @@index([evaluatorId])
  @@index([period])
}

model ManuscriptRevision {
  id                  String   @id @default(uuid())
  articleId           String
  revisionNumber      Int
  fileUrl             String
  coverLetter         String?
  responseToReviewers String?
  changesDescription  String?
  submittedBy         String
  submittedAt         DateTime @default(now())
  status              String   @default("PENDING")
  article             Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  submitter           User     @relation(fields: [submittedBy], references: [id])

  @@index([articleId])
  @@index([status])
}

model ManuscriptCommunication {
  id         String   @id @default(uuid())
  articleId  String
  fromUserId String?
  toUserId   String?
  subject    String
  message    String
  type       String
  isRead     Boolean  @default(false)
  sentAt     DateTime @default(now())
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  fromUser   User?    @relation("SentCommunications", fields: [fromUserId], references: [id])
  toUser     User?    @relation("ReceivedCommunications", fields: [toUserId], references: [id])

  @@index([articleId])
  @@index([toUserId])
  @@index([isRead])
}

model EmailTemplate {
  id          String              @id @default(uuid())
  name        String              @unique
  subject     String
  body        String
  variables   String[]
  category    String
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  companyId   String?
  designState Json?
  company     Company?            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaigns   MarketingCampaign[]

  @@index([category])
  @@index([isActive])
  @@index([companyId])
}

model CoAuthorInvitation {
  id          String    @id @default(uuid())
  articleId   String
  email       String
  name        String?
  affiliation String?
  invitedBy   String
  token       String    @unique
  status      String    @default("PENDING")
  expiresAt   DateTime
  respondedAt DateTime?
  createdAt   DateTime  @default(now())
  article     Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  inviter     User      @relation(fields: [invitedBy], references: [id])

  @@index([articleId])
  @@index([email])
  @@index([token])
  @@index([status])
}

model ITProject {
  id               String                @id @default(uuid())
  companyId        String
  projectCode      String                @unique
  name             String
  description      String?
  category         ProjectCategory       @default(DEVELOPMENT)
  type             ProjectType           @default(SUPPORT)
  status           ProjectStatus         @default(PLANNING)
  priority         Priority              @default(MEDIUM)
  clientId         String?
  clientType       ClientType?
  projectManagerId String?
  teamLeadId       String?
  startDate        DateTime?
  endDate          DateTime?
  estimatedHours   Float?
  actualHours      Float                 @default(0)
  isRevenueBased   Boolean               @default(false)
  estimatedRevenue Float                 @default(0)
  actualRevenue    Float                 @default(0)
  currency         String                @default("INR")
  itDepartmentCut  Float                 @default(0)
  itRevenueEarned  Float                 @default(0)
  billingType      BillingType?
  hourlyRate       Float?
  isBilled         Boolean               @default(false)
  invoiceId        String?
  tags             String[]
  attachments      String[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  completedAt      DateTime?
  about            String?
  departmentId     String?
  details          String?
  keywords         String[]
  websiteId        String?
  sharedWithIds    String[]
  visibility       ProjectVisibility     @default(PRIVATE)
  company          Company               @relation("CompanyITProjects", fields: [companyId], references: [id], onDelete: Cascade)
  department       Department?           @relation("DepartmentITProjects", fields: [departmentId], references: [id])
  projectManager   User?                 @relation("ProjectManager", fields: [projectManagerId], references: [id])
  teamLead         User?                 @relation("TeamLead", fields: [teamLeadId], references: [id])
  website          WebsiteMonitor?       @relation("WebsiteITProjects", fields: [websiteId], references: [id])
  comments         ITProjectComment[]
  documents        ITProjectDocument[]
  milestones       ITProjectMilestone[]
  suggestions      ITProjectSuggestion[]
  tasks            ITTask[]
  timeEntries      ITTimeEntry[]
  workPlans        WorkPlan[]
  taggedEmployees  User[]                @relation("ProjectTaggedEmployees")

  @@index([companyId])
  @@index([status])
  @@index([type])
  @@index([projectManagerId])
  @@index([isRevenueBased])
  @@index([departmentId])
  @@index([websiteId])
}

model ITTask {
  id              String                @id @default(uuid())
  companyId       String
  projectId       String?
  taskCode        String                @unique
  title           String
  description     String?
  category        TaskCategory          @default(GENERAL)
  type            TaskType              @default(SUPPORT)
  priority        Priority              @default(MEDIUM)
  status          TaskStatus            @default(PENDING)
  assignedToId    String?
  createdById     String
  reporterId      String?
  startDate       DateTime?
  dueDate         DateTime?
  completedAt     DateTime?
  estimatedHours  Float?
  actualHours     Float                 @default(0)
  isRevenueBased  Boolean               @default(false)
  estimatedValue  Float                 @default(0)
  actualValue     Float                 @default(0)
  currency        String                @default("INR")
  itDepartmentCut Float                 @default(0)
  itRevenueEarned Float                 @default(0)
  isPaid          Boolean               @default(false)
  paymentDate     DateTime?
  progressPercent Int                   @default(0)
  blockers        String?
  dependencies    String[]
  tags            String[]
  attachments     String[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  serviceId       String?
  assignedTo      User?                 @relation("ITTaskAssignee", fields: [assignedToId], references: [id])
  company         Company               @relation("CompanyITTasks", fields: [companyId], references: [id], onDelete: Cascade)
  createdBy       User                  @relation("ITTaskCreator", fields: [createdById], references: [id])
  project         ITProject?            @relation(fields: [projectId], references: [id])
  reporter        User?                 @relation("ITTaskReporter", fields: [reporterId], references: [id])
  service         ITServiceDefinition?  @relation("ServiceTasks", fields: [serviceId], references: [id])
  comments        ITTaskComment[]
  statusHistory   ITTaskStatusHistory[]
  timeEntries     ITTimeEntry[]
  workPlans       WorkPlan[]

  @@index([companyId])
  @@index([projectId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([status])
  @@index([type])
  @@index([isRevenueBased])
  @@index([priority])
}

model ITProjectDocument {
  id          String    @id @default(uuid())
  projectId   String
  name        String
  description String?
  url         String?
  fileType    String?
  fileSize    Int?      @default(0)
  category    String    @default("GENERAL")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  content     String?
  project     ITProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([category])
}

model ITProjectMilestone {
  id            String    @id @default(uuid())
  projectId     String
  name          String
  description   String?
  dueDate       DateTime
  completedAt   DateTime?
  status        String    @default("PENDING")
  paymentAmount Float?
  isPaid        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  project       ITProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

model ITTimeEntry {
  id          String     @id @default(uuid())
  companyId   String
  projectId   String?
  taskId      String?
  userId      String
  date        DateTime   @default(now())
  hours       Float
  description String?
  isBillable  Boolean    @default(false)
  hourlyRate  Float?
  amount      Float?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     Company    @relation("CompanyITTimeEntries", fields: [companyId], references: [id], onDelete: Cascade)
  project     ITProject? @relation(fields: [projectId], references: [id])
  task        ITTask?    @relation(fields: [taskId], references: [id])
  user        User       @relation("ITTimeEntries", fields: [userId], references: [id])

  @@index([companyId])
  @@index([projectId])
  @@index([taskId])
  @@index([userId])
  @@index([date])
}

model ITTaskStatusHistory {
  id             String     @id @default(uuid())
  taskId         String
  changedById    String
  previousStatus TaskStatus
  newStatus      TaskStatus
  comment        String?
  changedAt      DateTime   @default(now())
  changedBy      User       @relation("ITStatusChanger", fields: [changedById], references: [id])
  task           ITTask     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([changedById])
}

model ITProjectComment {
  id        String             @id @default(uuid())
  projectId String
  userId    String
  content   String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  parentId  String?
  parent    ITProjectComment?  @relation("ITProjectCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   ITProjectComment[] @relation("ITProjectCommentReplies")
  project   ITProject          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User               @relation("ITProjectComments", fields: [userId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@index([parentId])
}

model ITTaskComment {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  task      ITTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation("ITTaskComments", fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
}

model ITDepartmentRevenue {
  id             String   @id @default(uuid())
  companyId      String
  month          Int
  year           Int
  totalRevenue   Float    @default(0)
  projectRevenue Float    @default(0)
  taskRevenue    Float    @default(0)
  totalProjects  Int      @default(0)
  totalTasks     Int      @default(0)
  completedTasks Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation("CompanyITRevenue", fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, month, year])
  @@index([companyId])
  @@index([year, month])
}

model ITPerformanceMetric {
  id                    String   @id @default(uuid())
  companyId             String
  userId                String
  month                 Int
  year                  Int
  tasksCompleted        Int      @default(0)
  tasksInProgress       Int      @default(0)
  tasksCreated          Int      @default(0)
  averageCompletionTime Float    @default(0)
  revenueGenerated      Float    @default(0)
  billableHours         Float    @default(0)
  nonBillableHours      Float    @default(0)
  productivityScore     Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  company               Company  @relation("CompanyITPerformance", fields: [companyId], references: [id], onDelete: Cascade)
  user                  User     @relation("ITPerformance", fields: [userId], references: [id])

  @@unique([companyId, userId, month, year])
  @@index([companyId])
  @@index([userId])
  @@index([year, month])
}

model ITServiceDefinition {
  id            String   @id @default(uuid())
  companyId     String
  name          String
  description   String?
  category      String   @default("GENERAL")
  price         Float    @default(0)
  unit          String   @default("each")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  estimatedDays Int?
  company       Company  @relation("CompanyITServices", fields: [companyId], references: [id], onDelete: Cascade)
  tasks         ITTask[] @relation("ServiceTasks")

  @@index([companyId])
}

model RevenueTransaction {
  id                  String                      @id @default(uuid())
  companyId           String
  transactionNumber   String                      @unique
  amount              Float
  currency            String                      @default("INR")
  paymentMethod       String
  paymentDate         DateTime
  customerName        String?
  customerEmail       String?
  customerPhone       String?
  customerProfileId   String?
  institutionId       String?
  referenceNumber     String?
  bankName            String?
  proofDocument       String?
  claimedByEmployeeId String?
  approvedByManagerId String?
  departmentId        String?
  status              RevenueStatus               @default(PENDING)
  verificationStatus  VerificationStatus          @default(UNVERIFIED)
  verifiedAt          DateTime?
  workReportId        String?
  invoiceId           String?
  paymentId           String?
  description         String?
  notes               String?
  tags                Json?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  createdBy           String?
  revenueType         RevenueType?                @default(NEW)
  source              String?                     @default("Subscription")
  sourceOther         String?
  expenseAllocations  EmployeeExpenseAllocation[]
  claims              RevenueClaim[]
  approvedBy          EmployeeProfile?            @relation("ApprovedRevenue", fields: [approvedByManagerId], references: [id])
  claimedBy           EmployeeProfile?            @relation("ClaimedRevenue", fields: [claimedByEmployeeId], references: [id])
  company             Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerProfile     CustomerProfile?            @relation(fields: [customerProfileId], references: [id])
  department          Department?                 @relation(fields: [departmentId], references: [id])
  institution         Institution?                @relation(fields: [institutionId], references: [id])
  invoice             Invoice?                    @relation(fields: [invoiceId], references: [id])
  payment             Payment?                    @relation(fields: [paymentId], references: [id])
  workReport          WorkReport?                 @relation(fields: [workReportId], references: [id])

  @@index([companyId])
  @@index([transactionNumber])
  @@index([claimedByEmployeeId])
  @@index([status])
  @@index([paymentDate])
  @@index([customerProfileId])
}

model ExpenseAllocationRule {
  id           String     @id @default(uuid())
  companyId    String
  departmentId String
  percentage   Float      @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([companyId, departmentId])
  @@index([companyId])
}

model EmployeeExpenseAllocation {
  id                   String             @id @default(uuid())
  companyId            String
  employeeProfileId    String
  departmentId         String
  revenueTransactionId String
  amount               Float
  percentage           Float
  date                 DateTime           @default(now())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  company              Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department           Department         @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  employee             EmployeeProfile    @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)
  revenueTransaction   RevenueTransaction @relation(fields: [revenueTransactionId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([employeeProfileId])
  @@index([departmentId])
  @@index([revenueTransactionId])
}

model RevenueClaim {
  id                   String             @id @default(uuid())
  revenueTransactionId String
  employeeId           String
  workReportId         String?
  claimDate            DateTime           @default(now())
  claimAmount          Float
  claimReason          String?
  status               ClaimStatus        @default(PENDING)
  reviewedBy           String?
  reviewedAt           DateTime?
  reviewNotes          String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  employee             EmployeeProfile    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  revenueTransaction   RevenueTransaction @relation(fields: [revenueTransactionId], references: [id], onDelete: Cascade)
  workReport           WorkReport?        @relation(fields: [workReportId], references: [id])

  @@index([revenueTransactionId])
  @@index([employeeId])
  @@index([status])
}

model Account {
  id              String        @id @default(uuid())
  companyId       String
  code            String
  name            String
  type            AccountType
  description     String?
  parentAccountId String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentAccount   Account?      @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  subAccounts     Account[]     @relation("AccountHierarchy")
  journalLines    JournalLine[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([type])
}

model JournalEntry {
  id                  String                   @id @default(uuid())
  companyId           String
  entryNumber         String                   @unique
  date                DateTime
  description         String
  reference           String?
  status              String                   @default("DRAFT")
  postedBy            String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  company             Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                User?                    @relation(fields: [postedBy], references: [id])
  lines               JournalLine[]
  reconciliationLines BankReconciliationLine[]

  @@index([companyId])
  @@index([date])
  @@index([entryNumber])
}

model JournalLine {
  id             String       @id @default(uuid())
  journalEntryId String
  accountId      String
  description    String?
  debit          Decimal      @default(0) @db.Decimal(20, 2)
  credit         Decimal      @default(0) @db.Decimal(20, 2)
  account        Account      @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountId])
}

model BankReconciliationSession {
  id                String                   @id @default(uuid())
  companyId         String
  uploadedByUserId  String?
  sourceFileName    String?
  sourceType        String                   @default("CSV")
  status            String                   @default("ANALYZED")
  totalTransactions Int                      @default(0)
  matchedCount      Int                      @default(0)
  pendingCount      Int                      @default(0)
  unmatchedCount    Int                      @default(0)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  reviewedAt        DateTime?
  company           Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy        User?                    @relation("ReconciliationSessionUploader", fields: [uploadedByUserId], references: [id])
  lines             BankReconciliationLine[]

  @@index([companyId, createdAt])
  @@index([uploadedByUserId])
  @@index([status])
}

model BankReconciliationLine {
  id              String                    @id @default(uuid())
  sessionId       String
  journalEntryId  String?
  lineNumber      Int
  externalId      String?
  transactionDate DateTime
  description     String
  amount          Float
  transactionType String
  status          String                    @default("PENDING")
  matchConfidence Float?
  notes           String?
  rawData         Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  reconciledAt    DateTime?
  ignoredAt       DateTime?
  session         BankReconciliationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  journalEntry    JournalEntry?             @relation(fields: [journalEntryId], references: [id])

  @@index([sessionId, status])
  @@index([journalEntryId])
  @@index([transactionDate])
}

model TaxRate {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  code        String
  rate        Decimal  @db.Decimal(5, 2)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
}

model SystemEmailLog {
  id        String   @id @default(uuid())
  recipient String
  subject   String
  status    String
  messageId String?
  error     String?
  createdAt DateTime @default(now())
  metadata  Json?
}

model StageAssignment {
  id           String           @id @default(uuid())
  articleId    String
  stage        ManuscriptStatus
  assigneeId   String
  assignedById String
  status       String           @default("PENDING")
  comments     String?
  assignedAt   DateTime         @default(now())
  completedAt  DateTime?
  dueDate      DateTime?
  article      Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  assignedBy   User             @relation("TaskAssigner", fields: [assignedById], references: [id])
  assignee     User             @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([articleId])
  @@index([assigneeId])
  @@index([stage])
}

model Deal {
  id                String          @id @default(uuid())
  title             String
  value             Float           @default(0)
  currency          String          @default("INR")
  stage             DealStage       @default(DISCOVERY)
  probability       Int             @default(20)
  expectedCloseDate DateTime?
  customerId        String
  ownerId           String
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  companyId         String?
  company           Company?        @relation(fields: [companyId], references: [id])
  customer          CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  owner             User            @relation(fields: [ownerId], references: [id])

  @@index([customerId])
  @@index([ownerId])
  @@index([stage])
  @@index([companyId])
}

model GoalEvaluation {
  id          String       @id @default(uuid())
  goalId      String
  evaluatorId String
  score       Float
  feedback    String?
  createdAt   DateTime     @default(now())
  evaluator   User         @relation(fields: [evaluatorId], references: [id])
  goal        EmployeeGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model SalaryIncrementReview {
  id                 String                @id @default(uuid())
  incrementRecordId  String
  type               ReviewType            @default(MONTHLY)
  month              Int?
  year               Int?
  period             String?
  date               DateTime              @default(now())
  reviewerId         String
  revenueAchievement Float?                @default(0)
  kraProgress        String?
  kpiProgress        Json?
  rating             Float?
  comments           String?
  status             String                @default("COMPLETED")
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  incrementRecord    SalaryIncrementRecord @relation(fields: [incrementRecordId], references: [id], onDelete: Cascade)
  reviewer           User                  @relation("IncrementReviewer", fields: [reviewerId], references: [id])

  @@index([incrementRecordId])
  @@index([reviewerId])
}

model Project {
  id          String          @id @default(uuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  status      String          @default("PLANNED")
  priority    String          @default("MEDIUM")
  companyId   String
  managerId   String?
  leadId      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  issues      Issue[]
  company     Company         @relation(fields: [companyId], references: [id])
  lead        User?           @relation("BusinessTeamLead", fields: [leadId], references: [id])
  manager     User?           @relation("BusinessProjectManager", fields: [managerId], references: [id])
  members     ProjectMember[]
  tasks       Task[]
  workPlans   WorkPlan[]

  @@index([companyId])
  @@index([managerId])
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String?
  joinedAt  DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model Issue {
  id          String          @id @default(uuid())
  projectId   String?
  title       String
  description String?
  status      String          @default("OPEN")
  priority    String          @default("MEDIUM")
  type        String          @default("BUG")
  assigneeId  String?
  reporterId  String
  companyId   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  dueDate     DateTime?
  assignee    User?           @relation("IssueAssignee", fields: [assigneeId], references: [id])
  company     Company         @relation(fields: [companyId], references: [id])
  project     Project?        @relation(fields: [projectId], references: [id])
  reporter    User            @relation("IssueReporter", fields: [reporterId], references: [id])
  followUps   IssueFollowUp[]

  @@index([projectId])
  @@index([companyId])
  @@index([assigneeId])
}

model IssueFollowUp {
