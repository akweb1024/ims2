# Example Environment Variables
# Copy this file to .env and update with your actual values

# Database - Point to your PostgreSQL instance
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# JWT Secret (generate a strong one for production)
JWT_SECRET="your-super-secret-jwt-key"

# Web Push Notifications (use: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# Auth Config (NextAuth / Auth.js)
AUTH_SECRET="your-auth-secret-key"
NEXTAUTH_URL="http://localhost:3000"
CRON_SECRET="your-cron-secret"
PUBLIC_INVOICE_ACCESS_CODE="replace-with-a-shared-invoice-access-code"

# Encryption
CONFIG_ENCRYPTION_KEY="your-config-encryption-key"
THINK_TANK_ENCRYPTION_KEY="your-think-tank-encryption-key"

# Gemini / Google AI (optional, used for Think Tank duplicate embeddings)
GEMINI_API_KEY=""

# App Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
# Safety: prisma/seed.ts clears existing business data. Leave false for any real database.
ALLOW_DESTRUCTIVE_SEED="false"
CONFIRM_DESTRUCTIVE_SEED=""

# Safety: targeted leave-ledger repair script. Leave false unless running after a backup.
ALLOW_EMERGENCY_LEAVE_CLEANUP="false"
CONFIRM_EMERGENCY_LEAVE_CLEANUP=""

# WhatsApp Meta Webhook (optional, required only if using inbound/status webhooks)
WHATSAPP_META_VERIFY_TOKEN="ims-verification"
WHATSAPP_META_APP_SECRET="your-meta-app-secret"

# Prisma Client Engine (useful for certain deployment environments)
PRISMA_CLIENT_ENGINE_TYPE="library"

# Razorpay Config
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
