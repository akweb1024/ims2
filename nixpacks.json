{
  "providers": [
    "node"
  ],
  "variables": {
    "NPM_CONFIG_PRODUCTION": "false",
    "NIXPACKS_NODE_VERSION": "22",
    "NODE_OPTIONS": "--max-old-space-size=4096"
  },
  "phases": {
    "setup": {
      "nixPkgs": [
        "nodejs_22",
        "npm-9_x",
        "openssl",
        "bash"
      ]
    },
    "install": {
      "cmds": [
        "NODE_ENV=development npm install --no-audit --no-fund"
      ]
    },
    "build": {
      "cmds": [
        "npm run build"
      ]
    }
  },
  "start": {
    "cmd": "bash scripts/database-migrate.sh && NODE_ENV=production npm run start"
  }
}
